# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/flex_finances

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Telegram ────────────────────────────────────────────────────────────────
# Bot token from @BotFather. Used both for the companion bot and to verify the
# initData hash coming from the Mini App WebView.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Public HTTPS URL where the Mini App is hosted (required by Telegram).
# e.g. https://finances.flexacademy.uz
WEB_APP_URL=https://your-app.example.com

# ─── Auth ────────────────────────────────────────────────────────────────────
# Max age (seconds) an initData payload is accepted for. Prevents replay.
INIT_DATA_MAX_AGE_SECONDS=86400

# Set to "1" to bypass Telegram initData verification during local development
# and authenticate as DEV_TELEGRAM_ID instead. NEVER enable in production.
DEV_AUTH_BYPASS=0
DEV_TELEGRAM_ID=

# ─── Seeding ─────────────────────────────────────────────────────────────────
# Telegram user ID + name for the first CEO account created by `npm run seed`.
SEED_CEO_TELEGRAM_ID=
SEED_CEO_NAME=Flex Academy CEO

# ─── Business defaults ───────────────────────────────────────────────────────
# Days after the 1st of the month before an unpaid student becomes "overdue".
DEFAULT_GRACE_PERIOD_DAYS=5
# Default currency for stored monetary values.
DEFAULT_CURRENCY=UZS
